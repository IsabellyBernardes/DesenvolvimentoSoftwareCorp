package ifpe.paokentyn.test;

import ifpe.paokentyn.domain.Fornada;
import ifpe.paokentyn.domain.Padaria;
import ifpe.paokentyn.repository.FornadaRepositorio;
import ifpe.paokentyn.repository.PadariaRepositorio;

import java.util.Calendar;
import java.util.Date;

public class TesteFornada {
    
    // Repositórios assumidos
    private final static PadariaRepositorio padariaRepositorio = new PadariaRepositorio();
    private final static FornadaRepositorio fornadaRepositorio = new FornadaRepositorio();
    
    // Variavel para armazenar a Padaria criada
    private static Padaria padariaBase;

    public static void main(String[] args) {
        // 1. Configuração inicial: garante que uma Padaria exista
        configurarPadariaBase(); 
        
        // 2. Executa os testes de CRUD
        if (padariaBase != null) {
            testarPersistencia(padariaBase);
            testarConsultaPorId(1L);
        } else {
            System.err.println("Erro: Não foi possível configurar a Padaria base para o teste.");
        }
    }

    // Cria e salva uma Padaria para ser usada como chave estrangeira.
     
    public static void configurarPadariaBase() {
        System.out.println("=== CONFIGURANDO PADARIA BASE ===");
        Padaria padaria = new Padaria();
        padaria.setNome("Padaria Central do Teste");
        padaria.setCep("50000000"); // Usando um CEP simples
        // Salvar Padaria (assumindo que o repositório salva e retorna a entidade gerenciada com ID)
        padariaRepositorio.salvar(padaria);
        padariaBase = padaria;
        System.out.println("Padaria Base criada com ID: " + padariaBase.getId());
    }
    
    // Testa a persistência (salvamento) de uma nova Fornada.
    
    public static void testarPersistencia(Padaria padaria) {
        System.out.println("\n=== TESTE PERSISTÊNCIA FORNADA ===");
        
        // Data de ontem para cumprir a restrição @Past em dataFornada
        Date dataFornada = getData(Calendar.getInstance().get(Calendar.DAY_OF_MONTH) - 1, Calendar.NOVEMBER, 2025);
        
        // Hora de agora (apenas o componente TIME será salvo)
        Date horaInicio = new Date(); 
        
        Fornada fornada = new Fornada();
        fornada.setPadaria(padaria); // FK obrigatória
        fornada.setDataFornada(dataFornada);
        fornada.setHoraInicio(horaInicio);
        
        fornadaRepositorio.salvar(fornada);
        System.out.println("Fornada cadastrada com ID: " + fornada.getId());
    }

    // Testa a consulta de uma Fornada pelo seu ID.
    
    public static void testarConsultaPorId(Long id) {
        System.out.println("\n=== TESTE CONSULTA POR ID FORNADA ===");
        
        Fornada fornada = fornadaRepositorio.encontrarPorID(id);
        
        if (fornada != null) {
            // O uso de getDate/getTime é para mostrar apenas o componente relevante, como exigido pelo @Temporal
            System.out.println("Fornada encontrada (ID: " + fornada.getId() + ")");
            System.out.println("Data: " + formatarData(fornada.getDataFornada()));
            System.out.println("Hora Início: " + formatarHora(fornada.getHoraInicio()));
            System.out.println("Padaria Associada: " + fornada.getPadaria().getNome()); // Acesso LAZY
        } else {
            System.out.println("Fornada com ID " + id + " não encontrada.");
        }
    }

    // --- Métodos Auxiliares ---
    
    [cite_start]// Método auxiliar adaptado do material da Aula 5 [cite: 694]
    private static Date getData(int dia, int mes, int ano) {
        Calendar calendar = Calendar.getInstance();
        calendar.set(Calendar.YEAR, ano);
        calendar.set(Calendar.MONTH, mes);
        calendar.set(Calendar.DAY_OF_MONTH, dia);
        calendar.set(Calendar.HOUR_OF_DAY, 0);
        calendar.set(Calendar.MINUTE, 0);
        calendar.set(Calendar.SECOND, 0);
        calendar.set(Calendar.MILLISECOND, 0);
        return calendar.getTime();
    }
    
    // Simulação de formatação para clareza
    private static String formatarData(Date date) {
        return String.format("%tD", date);
    }

    private static String formatarHora(Date date) {
        return String.format("%tT", date);
    }
}
